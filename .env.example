# Configurações da aplicação
ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Configurações do servidor
HOST=0.0.0.0
PORT=8050

# Configurações de logs
LOG_LEVEL=INFO

# Intervalo de refresh padrão (segundos)
DEFAULT_REFRESH_INTERVAL=0


# =============================================================================
# EXEMPLOS DE CONFIGURAÇÃO DE FONTE DE DADOS
# =============================================================================

# ---------- EXEMPLO 1: PostgreSQL ----------
# database:
#   type: postgresql
#   host: ${DB_HOST}
#   port: 5432
#   name: ${DB_NAME}
#   user: ${DB_USER}
#   password: ${DB_PASSWORD}

# ---------- EXEMPLO 2: MySQL ----------
# database:
#   type: mysql
#   host: ${DB_HOST}
#   port: 3306
#   name: ${DB_NAME}
#   user: ${DB_USER}
#   password: ${DB_PASSWORD}

# ---------- EXEMPLO 3: CSV (Arquivo Local) ----------
# database:
#   type: csv
#   path: ${CSV_PATH}  # Caminho do arquivo CSV

# ---------- EXEMPLO 4: CSV com Query ----------
# database:
#   type: csv
#   path: ${CSV_PATH}
#   query: "SELECT * FROM arquivo WHERE coluna > 100"


# =============================================================================
# CONFIGURAÇÃO ATUAL - BORBA (PostgreSQL Supabase)
# =============================================================================
DB_BORBA=
DB_PORT=
DB_NAME=
DB_USER=
DB_BORBA_PASS=


